							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "[\n  {\n    \"taskId\": \"test-001\",\n    \"clienttransId\": \"tx-001\",\n    \"senderAddress\": \"TEST\",\n    \"destinationAddress\": \"8801711111111\",\n    \"messageText\": \"Test message\",\n    \"username\": \"testuser\",\n    \"password\": \"testpass123\",\n    \"priority\": \"NORMAL\"\n  }\n]"
